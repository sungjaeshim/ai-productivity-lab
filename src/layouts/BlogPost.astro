---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, heroImageAlt, heroImageCredit } = Astro.props;

// 언어 자동 감지: 제목이 한글로 시작하면 ko, 아니면 en
const isKorean = /^[가-힣\s]/.test(title) || /[가-힣]/.test(title.slice(0, 20));
const lang = isKorean ? 'ko' : 'en';

// Article 메타데이터 for Schema.org
const articleMeta = {
	publishedTime: pubDate.toISOString(),
	modifiedTime: updatedDate?.toISOString(),
	author: 'AI Snowball'
};
---

<html lang={lang}>
	<head>
		<BaseHead 
			title={title} 
			description={description} 
			image={heroImage}
			article={articleMeta}
			lang={lang}
		/>
		<style>
			main {
				width: min(var(--reading-width) + 120px, calc(100% - 2rem));
				max-width: 100%;
				margin: 0 auto;
			}
			.story-shell {
				display: grid;
				grid-template-columns: minmax(0, 1fr);
				gap: 1rem;
			}
			.hero-block {
				padding: 1.25rem 1.25rem 1.1rem;
				background: var(--bg-card);
			}
			.hero-image {
				width: 100%;
				max-width: 100%;
				margin: 0 auto;
			}
			.hero-image img {
				border-radius: 10px;
				border: 1px solid var(--border);
			}
			.hero-credit {
				text-align: left;
				font-size: 0.75rem;
				color: var(--ink-soft);
				margin-top: 0.5rem;
			}
			.prose {
				width: min(var(--reading-width), 100%);
				max-width: 100%;
				margin: auto;
				padding: 1rem 0 0;
				color: var(--ink);
			}
			.title {
				margin-bottom: 1rem;
				padding: 0;
				text-align: left;
				line-height: 1.15;
			}
			.title h1 {
				margin: 0 0 0.5rem 0;
				max-width: 100%;
				font-size: clamp(1.85rem, 3.8vw, 2.5rem);
			}
			.date {
				display: flex;
				flex-wrap: wrap;
				gap: 0.5rem 1rem;
				align-items: center;
				margin-bottom: 0.85rem;
				color: var(--ink-soft);
				font-size: 0.84rem;
				font-family: var(--font-mono);
				letter-spacing: 0.03em;
			}
			.last-updated-on {
				font-style: normal;
			}
			.deck {
				max-width: 64ch;
				font-size: 0.98rem;
				margin-bottom: 0;
			}
			.story-meta {
				display: flex;
				align-items: center;
				gap: 0.55rem;
				margin-bottom: 0.85rem;
				flex-wrap: wrap;
			}
			.story-kicker {
				font-family: var(--font-mono);
				font-size: 0.72rem;
				letter-spacing: 0.08em;
				text-transform: uppercase;
				color: var(--ink-soft);
			}
			hr {
				margin: 1rem 0 0;
			}
			.prose :global(p),
			.prose :global(li) {
				font-size: 1rem;
			}
			.prose :global(h2) {
				margin-top: 2.2rem;
			}
			.prose :global(h3) {
				margin-top: 1.5rem;
			}
			.prose :global(ul),
			.prose :global(ol) {
				padding-left: 1.2rem;
			}
			@media (max-width: 720px) {
				.hero-block {
					padding: 1rem 1rem 0.9rem;
				}
				.prose {
					padding-top: 0.8rem;
				}
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="story-shell">
					<div class="hero-block panel">
						<div class="prose">
							<div class="story-meta">
								<span class="eyebrow">{lang === 'ko' ? 'Field Guide' : 'Operator Note'}</span>
								<span class="story-kicker">AI Snowball</span>
							</div>
							<div class="title">
								<div class="date">
									<span><FormattedDate date={pubDate} /></span>
									{
										updatedDate && (
											<div class="last-updated-on">
												{lang === 'ko' ? '마지막 수정' : 'Updated'} <FormattedDate date={updatedDate} />
											</div>
										)
									}
								</div>
								<h1 class="line-clamp-3">{title}</h1>
								<p class="deck">{description}</p>
								<hr />
							</div>
						</div>
						{heroImage && (
							<div class="hero-image">
								<img src={heroImage} alt={heroImageAlt || title} loading="eager" decoding="async" width="1440" height="810" />
								{heroImageCredit && <p class="hero-credit" set:html={heroImageCredit} />}
							</div>
						)}
					</div>
					<div class="prose">
						<slot />
					</div>
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
