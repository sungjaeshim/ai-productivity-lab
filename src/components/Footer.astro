---
const today = new Date();
---

<footer>
	<p class="brand">AI Snowball</p>
	<p class="tagline">Practical AI workflows, automation notes, and operator-grade writing.</p>
	<p>&copy; {today.getFullYear()} AI Snowball. All rights reserved.</p>
	<nav>
		<a href="/about">소개</a> · 
		<a href="/terms">이용약관</a> · 
		<a href="/privacy">개인정보처리방침</a> · 
		<a href="/rss.xml">RSS</a>
	</nav>
</footer>
<style>
	footer {
		border-top: 1px solid var(--border);
		padding: 2.5rem 1rem 3.5rem;
		text-align: center;
		color: var(--ink-soft);
		font-size: 0.88rem;
	}
	.brand {
		font-size: 0.98rem;
		font-weight: 800;
		letter-spacing: -0.02em;
		color: var(--ink);
		margin-bottom: 0.25rem;
	}
	.tagline {
		max-width: 34rem;
		margin: 0 auto 0.75rem;
	}
	footer nav {
		margin-top: 0.5rem;
	}
	footer a {
		color: var(--accent-dark);
		text-decoration: none;
	}
	footer a:hover { text-decoration: underline; }
</style>
