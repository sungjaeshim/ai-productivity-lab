# Sentry DSN Template
# 복사해서 실제 값으로 교체 후 사용
# 절대 이 파일을 그대로 커밋하지 말 것

# =============================================================================
# Production DSNs
# =============================================================================
SENTRY_DSN_GROWTH_CENTER=https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx@o123456.ingest.sentry.io/1234567
SENTRY_DSN_BLOG=https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx@o123456.ingest.sentry.io/1234568
SENTRY_DSN_CEO_AI=https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx@o123456.ingest.sentry.io/1234569
SENTRY_DSN_MACD_BOT=https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx@o123456.ingest.sentry.io/1234570

# =============================================================================
# Staging DSNs (선택사항 - 환경 분리 시 사용)
# =============================================================================
# STAGING_SENTRY_DSN_GROWTH_CENTER=https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx@o123456.ingest.sentry.io/2234567
# STAGING_SENTRY_DSN_BLOG=https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx@o123456.ingest.sentry.io/2234568
# STAGING_SENTRY_DSN_CEO_AI=https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx@o123456.ingest.sentry.io/2234569
# STAGING_SENTRY_DSN_MACD_BOT=https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx@o123456.ingest.sentry.io/2234570

# =============================================================================
# Development DSNs (선택사항 - 로컬 개발 시 사용)
# =============================================================================
# DEV_SENTRY_DSN_GROWTH_CENTER=https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx@o123456.ingest.sentry.io/3234567
# DEV_SENTRY_DSN_BLOG=https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx@o123456.ingest.sentry.io/3234568
# DEV_SENTRY_DSN_CEO_AI=https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx@o123456.ingest.sentry.io/3234569
# DEV_SENTRY_DSN_MACD_BOT=https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx@o123456.ingest.sentry.io/3234570

# =============================================================================
# 공통 설정 (선택사항)
# =============================================================================
# SENTRY_ENVIRONMENT=production
# SENTRY_RELEASE=1.0.0
# SENTRY_TRACES_SAMPLE_RATE=0.1

# =============================================================================
# 사용 방법
# =============================================================================
# 1. 이 파일을 복사: cp config/sentry-dsn-template.env .env.sentry
# 2. 실제 DSN 값으로 교체 (Sentry 대시보드에서 확인)
# 3. 서비스에 주입:
#    - Docker: env_file: - .env.sentry
#    - Systemd: EnvironmentFile=/path/to/.env.sentry
#    - Kubernetes: kubectl create secret generic sentry-dsn --from-env-file=.env.sentry
# 4. .env.sentry를 .gitignore에 추가
# =============================================================================
